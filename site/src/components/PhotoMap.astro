---
// A Leaflet map of GPS points. Renders nothing when there are no points.
// Props: points [{lat,lon,photos:[{title,thumb,href}]}], id, cluster, height, caption.
const { points = [], id, cluster = false, height = '380px', caption } = Astro.props;
const hasPoints = points.length > 0;
---

{
  hasPoints && (
    <Fragment>
      <figure class="map-frame">
        <div id={id} class="map" style={`height:${height}`} />
        {caption && <figcaption>{caption}</figcaption>}
      </figure>

      <script is:inline define:vars={{ points, id, cluster }}>
        (function () {
          if (typeof L === 'undefined') return;
          const map = L.map(id, { scrollWheelZoom: false }).setView([0, 0], 2);
          L.tileLayer('https://{s}.basemaps.cartocdn.com/dark_all/{z}/{x}/{y}{r}.png', {
            attribution: '&copy; OpenStreetMap, &copy; CARTO',
            subdomains: 'abcd',
            maxZoom: 19,
          }).addTo(map);

          const useCluster = cluster && typeof L.markerClusterGroup === 'function';
          const layer = useCluster ? L.markerClusterGroup() : L.layerGroup();
          const latlngs = [];

          const esc = (s) => String(s || '').replace(/[<>&"]/g, (c) => ({ '<': '&lt;', '>': '&gt;', '&': '&amp;', '"': '&quot;' })[c]);

          for (const p of points) {
            const photos = p.photos || [];
            const marker = L.circleMarker([p.lat, p.lon], {
              radius: 5 + Math.min(4, Math.round(Math.sqrt(photos.length))),
              color: '#58d2c6',
              weight: 2,
              fillColor: '#58d2c6',
              fillOpacity: 0.5,
            });

            let html;
            if (photos.length <= 1) {
              const ph = photos[0] || {};
              const thumb = ph.thumb ? `<img src="${ph.thumb}" alt="" />` : '';
              html = `<a class="map-pop" href="${ph.href}">${thumb}<span>${esc(ph.title)}</span></a>`;
            } else {
              const items = photos
                .map((ph) => `<a class="map-pop-item" href="${ph.href}" title="${esc(ph.title)}"><img src="${ph.thumb}" alt="" /></a>`)
                .join('');
              html = `<div class="map-pop-multi"><div class="map-pop-count">${photos.length} photos here</div><div class="map-pop-grid">${items}</div></div>`;
            }
            marker.bindPopup(html, { maxWidth: 232, maxHeight: 260 });
            layer.addLayer(marker);
            latlngs.push([p.lat, p.lon]);
          }
          map.addLayer(layer);

          if (latlngs.length === 1) map.setView(latlngs[0], 9);
          else map.fitBounds(latlngs, { padding: [30, 30] });
        })();
      </script>
    </Fragment>
  )
}
