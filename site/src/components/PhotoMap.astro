---
// A flat MapLibre GL map of GPS points, themed to the site palette. Renders
// nothing when there are no points.
// Props: points [{lat,lon,photos:[{title,thumb,href}]}], id, cluster, height, caption.
// `cluster` → GeoJSON clustering for the global (home) map; otherwise HTML
// markers fit to a trip. The MapTiler key is a client-side, domain-restricted
// value read from PUBLIC_MAPTILER_KEY.
import { buildStyle } from '../lib/mapStyle.js';
const { points = [], id, cluster = false, link = false, height = '380px', caption } = Astro.props;
const mapStyle = buildStyle(import.meta.env.PUBLIC_MAPTILER_KEY || '');
const hasPoints = points.length > 0;
---

{
  hasPoints && (
    <Fragment>
      <figure class="map-frame">
        <div id={id} class="map" style={`height:${height}`} />
        {caption && <figcaption>{caption}</figcaption>}
      </figure>

      <script is:inline define:vars={{ points, id, cluster, link, mapStyle }}>
        (function () {
          if (typeof maplibregl === 'undefined') return;
          const el = document.getElementById(id);
          if (!mapStyle) {
            el.innerHTML = '<div class="map-msg">Set PUBLIC_MAPTILER_KEY to show the map</div>';
            return;
          }

          const map = new maplibregl.Map({
            container: id,
            style: mapStyle,
            center: cluster ? [10, 25] : [points[0].lon, points[0].lat],
            zoom: cluster ? 1.4 : 4,
            attributionControl: { compact: true },
            cooperativeGestures: true,
            dragRotate: false,
            pitchWithRotate: false,
          });
          map.addControl(new maplibregl.NavigationControl({ showCompass: false }), 'top-right');

          const popup = new maplibregl.Popup({ closeButton: true, maxWidth: '232px' });
          const esc = (s) => String(s || '').replace(/[<>&"]/g, (c) => ({ '<': '&lt;', '>': '&gt;', '&': '&amp;', '"': '&quot;' })[c]);
          function popupHtml(photos) {
            if (photos.length <= 1) {
              const ph = photos[0] || {};
              const thumb = ph.thumb ? `<img src="${ph.thumb}" alt="" />` : '';
              return `<a class="map-pop" href="${ph.href}">${thumb}<span>${esc(ph.title)}</span></a>`;
            }
            const items = photos
              .map((ph) => `<a class="map-pop-item" href="${ph.href}" title="${esc(ph.title)}"><img src="${ph.thumb}" alt="" /></a>`)
              .join('');
            return `<div class="map-pop-multi"><div class="map-pop-count">${photos.length} photos here</div><div class="map-pop-grid">${items}</div></div>`;
          }

          function fit() {
            if (points.length === 1) {
              map.setCenter([points[0].lon, points[0].lat]);
              map.setZoom(9);
              return;
            }
            const b = new maplibregl.LngLatBounds();
            for (const p of points) b.extend([p.lon, p.lat]);
            map.fitBounds(b, { padding: 44, maxZoom: cluster ? 6 : 11, duration: 0 });
          }

          map.on('load', () => {
            cluster ? buildCluster() : buildMarkers();
            fit();
            // compact:true starts EXPANDED; collapse it so only the ⓘ shows.
            el.querySelector('.maplibregl-ctrl-attrib')?.classList.remove('maplibregl-compact-show');
            if (link) setupLink();
          });

          // Tell the page which trips are in the current viewport (for filtering
          // the trip grid), and react to a reset request.
          function setupLink() {
            const emit = () => {
              const b = map.getBounds();
              const slugs = new Set();
              for (const p of points) if (b.contains([p.lon, p.lat])) for (const s of p.slugs || []) slugs.add(s);
              document.dispatchEvent(new CustomEvent('photomap:view', { detail: { slugs: [...slugs] } }));
            };
            map.on('moveend', emit);
            emit();
            document.addEventListener('photomap:reset', () => {
              const b = new maplibregl.LngLatBounds();
              for (const p of points) b.extend([p.lon, p.lat]);
              map.fitBounds(b, { padding: 44, maxZoom: 6 });
            });
          }

          // Trip map: HTML markers reusing the .map-pin count badges.
          function buildMarkers() {
            for (const p of points) {
              const n = p.photos.length;
              const sz = n > 1 ? Math.min(36, 18 + n) : 13;
              const pin = document.createElement('div');
              pin.className = 'map-pin' + (n > 1 ? ' multi' : '');
              pin.style.width = pin.style.height = sz + 'px';
              if (n > 1) pin.textContent = String(n);
              pin.addEventListener('click', (e) => {
                e.stopPropagation();
                popup.setLngLat([p.lon, p.lat]).setHTML(popupHtml(p.photos)).addTo(map);
              });
              new maplibregl.Marker({ element: pin }).setLngLat([p.lon, p.lat]).addTo(map);
            }
          }

          // Global map: native GeoJSON clustering, styled to match the badges.
          function buildCluster() {
            map.addSource('photos', {
              type: 'geojson',
              cluster: true,
              clusterRadius: 44,
              clusterMaxZoom: 8,
              // Sum the per-spot photo counts so a cluster shows total photos,
              // not the number of locations.
              clusterProperties: { total: ['+', ['get', 'count']] },
              data: {
                type: 'FeatureCollection',
                features: points.map((p) => ({
                  type: 'Feature',
                  geometry: { type: 'Point', coordinates: [p.lon, p.lat] },
                  properties: { count: p.photos.length, photos: JSON.stringify(p.photos), slugs: JSON.stringify(p.slugs || []) },
                })),
              },
            });
            map.addLayer({
              id: 'clusters', type: 'circle', source: 'photos', filter: ['has', 'point_count'],
              paint: {
                'circle-color': '#58d2c6', 'circle-opacity': 0.9, 'circle-stroke-color': '#06121a', 'circle-stroke-width': 2,
                'circle-radius': ['step', ['get', 'total'], 15, 20, 20, 75, 26],
              },
            });
            map.addLayer({
              id: 'cluster-count', type: 'symbol', source: 'photos', filter: ['has', 'point_count'],
              layout: { 'text-field': ['to-string', ['get', 'total']], 'text-font': ['Noto Sans Bold'], 'text-size': 12 },
              paint: { 'text-color': '#06121a' },
            });
            map.addLayer({
              id: 'point', type: 'circle', source: 'photos', filter: ['!', ['has', 'point_count']],
              paint: {
                'circle-color': '#58d2c6', 'circle-stroke-color': '#06121a', 'circle-stroke-width': 2,
                'circle-opacity': ['case', ['>', ['get', 'count'], 1], 0.95, 0.6],
                'circle-radius': ['interpolate', ['linear'], ['get', 'count'], 1, 6, 3, 9, 10, 13],
              },
            });
            map.addLayer({
              id: 'point-count', type: 'symbol', source: 'photos',
              filter: ['all', ['!', ['has', 'point_count']], ['>', ['get', 'count'], 1]],
              layout: { 'text-field': ['to-string', ['get', 'count']], 'text-font': ['Noto Sans Bold'], 'text-size': 11 },
              paint: { 'text-color': '#06121a' },
            });

            const pointer = (on) => () => (map.getCanvas().style.cursor = on ? 'pointer' : '');
            for (const lyr of ['clusters', 'point']) {
              map.on('mouseenter', lyr, pointer(true));
              map.on('mouseleave', lyr, pointer(false));
            }
            map.on('click', 'clusters', (e) => {
              const f = map.queryRenderedFeatures(e.point, { layers: ['clusters'] })[0];
              map.getSource('photos').getClusterExpansionZoom(f.properties.cluster_id).then((zoom) => {
                map.easeTo({ center: f.geometry.coordinates, zoom });
              });
            });
            map.on('click', 'point', (e) => {
              const f = e.features[0];
              popup.setLngLat(f.geometry.coordinates).setHTML(popupHtml(JSON.parse(f.properties.photos))).addTo(map);
              if (link && f.properties.slugs) {
                document.dispatchEvent(new CustomEvent('photomap:select', { detail: { slugs: JSON.parse(f.properties.slugs) } }));
              }
            });
          }
        })();
      </script>
    </Fragment>
  )
}
