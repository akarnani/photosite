---
// Masonry gallery of <picture> elements + a click-to-open lightbox.
// Props: photos (already merged: file, width, height, ratio, lqip, fallback,
// srcset, species, caption, title, exposure, camera, lens).
import { buildStyle } from '../lib/mapStyle.js';
const { photos = [] } = Astro.props;

const SIZES = '(min-width:1300px) 25vw, (min-width:900px) 33vw, (min-width:540px) 50vw, 100vw';
const srcsetStr = (p) => p.srcset.map((s) => `${s.url} ${s.w}w`).join(', ');

// Themed style for the lightbox inset map (null without a key → no map button).
const mapStyle = buildStyle(import.meta.env.PUBLIC_MAPTILER_KEY || '');

// Minimal per-photo data the lightbox needs, embedded as JSON.
const lbData = photos.map((p) => ({
  id: p.id,
  fallback: p.fallback,
  srcset: srcsetStr(p),
  species: p.species || [],
  caption: p.caption || null,
  title: p.title || null,
  date: p.date || null,
  gps: p.gps || null,
  exposure: p.exposure || null,
  camera: p.camera || null,
  lens: p.lens || null,
}));
---

<div class="gallery" data-gallery>
  {
    photos.map((p, i) => (
      <button class="shot" id={p.id} data-index={i} style={`aspect-ratio:${p.ratio}`} aria-label={p.title || p.species?.[0] || p.file}>
        <picture>
          <source type="image/webp" srcset={srcsetStr(p)} sizes={SIZES} />
          <img
            src={p.fallback}
            width={p.width}
            height={p.height}
            alt={p.title || p.species?.[0] || ''}
            loading="lazy"
            decoding="async"
            style={`background-image:url(${p.lqip})`}
          />
        </picture>
        {(p.species?.length || p.caption) && (
          <span class="shot-meta">
            {p.species?.length ? <em class="species">{p.species.join(' · ')}</em> : null}
            {p.caption ? <span class="note">{p.caption}</span> : null}
          </span>
        )}
      </button>
    ))
  }
</div>

<script type="application/json" data-lightbox-data set:html={JSON.stringify(lbData)} />
<script type="application/json" data-map-style set:html={JSON.stringify(mapStyle)} />

<script>
  // One lightbox per page, shared across galleries. Vanilla, no dependency.
  function initLightbox() {
    const dataEl = document.querySelector('[data-lightbox-data]');
    const gallery = document.querySelector('[data-gallery]');
    if (!dataEl || !gallery) return;
    const photos = JSON.parse(dataEl.textContent || '[]');

    const overlay = document.createElement('div');
    overlay.className = 'lightbox';
    overlay.innerHTML = `
      <div class="lb-actions">
        <button class="lb-copy" aria-label="Copy link to this photo">Copy link</button>
        <button class="lb-map-btn" aria-label="Show location" aria-expanded="false" hidden>Map</button>
      </div>
      <button class="lb-close" aria-label="Close">×</button>
      <button class="lb-prev" aria-label="Previous">‹</button>
      <button class="lb-next" aria-label="Next">›</button>
      <figure>
        <img alt="" />
        <figcaption>
          <span class="lb-title"></span>
          <span class="lb-species"></span>
          <p class="lb-note"></p>
          <span class="lb-date"></span>
          <span class="lb-exif"></span>
        </figcaption>
      </figure>
      <div class="lb-map" hidden></div>`;
    document.body.appendChild(overlay);

    const styleEl = document.querySelector('[data-map-style]');
    const mapStyle = styleEl ? JSON.parse(styleEl.textContent || 'null') : null;

    const img = overlay.querySelector('img');
    const elTitle = overlay.querySelector('.lb-title');
    const elSpecies = overlay.querySelector('.lb-species');
    const elNote = overlay.querySelector('.lb-note');
    const elDate = overlay.querySelector('.lb-date');
    const elExif = overlay.querySelector('.lb-exif');
    const mapBtn = overlay.querySelector('.lb-map-btn');
    const mapBox = overlay.querySelector('.lb-map');
    let current = 0;
    let insetMap = null;
    let insetMarker = null;

    function fmtDate(iso) {
      if (!iso) return '';
      const d = new Date(iso);
      if (isNaN(d)) return '';
      const date = d.toLocaleDateString(undefined, { year: 'numeric', month: 'long', day: 'numeric' });
      if (!d.getHours() && !d.getMinutes()) return date;
      return `${date} · ${d.toLocaleTimeString(undefined, { hour: '2-digit', minute: '2-digit' })}`;
    }

    function hideInset() {
      mapBox.hidden = true;
      mapBtn.setAttribute('aria-expanded', 'false');
    }
    function showInset() {
      const g = photos[current].gps;
      if (!g || !mapStyle) return;
      mapBox.hidden = false;
      mapBtn.setAttribute('aria-expanded', 'true');
      if (!insetMap) {
        insetMap = new maplibregl.Map({
          container: mapBox,
          style: mapStyle,
          center: [g.lon, g.lat],
          zoom: 6,
          attributionControl: { compact: true },
          dragRotate: false,
        });
        insetMap.on('load', () =>
          insetMap.getContainer().querySelector('.maplibregl-ctrl-attrib')?.classList.remove('maplibregl-compact-show'),
        );
        const pin = document.createElement('div');
        pin.className = 'map-pin';
        pin.style.width = pin.style.height = '13px';
        insetMarker = new maplibregl.Marker({ element: pin }).setLngLat([g.lon, g.lat]).addTo(insetMap);
      } else {
        insetMarker.setLngLat([g.lon, g.lat]);
        insetMap.setCenter([g.lon, g.lat]);
      }
      requestAnimationFrame(() => insetMap.resize());
    }
    function updateMapBtn() {
      const has = !!(mapStyle && photos[current].gps && typeof maplibregl !== 'undefined');
      mapBtn.hidden = !has;
      if (!has) hideInset();
      else if (!mapBox.hidden) showInset();
    }

    const setLine = (el, text) => {
      el.textContent = text || '';
      el.style.display = text ? '' : 'none';
    };

    const fmtShutter = (t) => (t >= 1 ? `${t}s` : `1/${Math.round(1 / t)}s`);
    function fmtExif(p) {
      const e = p.exposure || {};
      const parts = [];
      if (e.fNumber != null) parts.push(`f/${e.fNumber}`);
      if (e.exposureTime != null) parts.push(fmtShutter(e.exposureTime));
      if (e.iso != null) parts.push(`ISO ${e.iso}`);
      if (e.focalLength != null) parts.push(`${e.focalLength}mm`);
      const gear = [p.camera, p.lens].filter(Boolean).join(' · ');
      return [parts.join(' · '), gear].filter(Boolean).join('  —  ');
    }

    const isOpen = () => overlay.classList.contains('open');
    const baseUrl = () => location.pathname + location.search;
    const idIndex = (id) => photos.findIndex((p) => p.id === id);

    function show(i) {
      current = (i + photos.length) % photos.length;
      const p = photos[current];
      img.src = p.fallback;
      img.srcset = p.srcset;
      img.sizes = '90vw';
      setLine(elTitle, p.title);
      setLine(elSpecies, (p.species || []).join(' · '));
      setLine(elNote, p.caption);
      setLine(elDate, fmtDate(p.date));
      setLine(elExif, fmtExif(p));
      updateMapBtn();
      // Reflect the current photo in the URL (no history spam) so it's shareable.
      history.replaceState(null, '', p.id ? `${baseUrl()}#${p.id}` : baseUrl());
    }
    function open(i) {
      show(i);
      overlay.classList.add('open');
      document.body.style.overflow = 'hidden';
    }
    function close() {
      overlay.classList.remove('open');
      document.body.style.overflow = '';
      hideInset();
      history.replaceState(null, '', baseUrl());
    }

    gallery.querySelectorAll('.shot').forEach((btn) => {
      btn.addEventListener('click', () => open(Number(btn.dataset.index)));
    });
    overlay.querySelector('.lb-close').addEventListener('click', close);
    overlay.querySelector('.lb-prev').addEventListener('click', () => show(current - 1));
    overlay.querySelector('.lb-next').addEventListener('click', () => show(current + 1));
    overlay.addEventListener('click', (e) => {
      if (e.target === overlay) close();
    });
    document.addEventListener('keydown', (e) => {
      if (!isOpen()) return;
      if (e.key === 'Escape') close();
      else if (e.key === 'ArrowLeft') show(current - 1);
      else if (e.key === 'ArrowRight') show(current + 1);
    });

    mapBtn.addEventListener('click', () => (mapBox.hidden ? showInset() : hideInset()));

    const copyBtn = overlay.querySelector('.lb-copy');
    copyBtn.addEventListener('click', async () => {
      const url = location.origin + baseUrl() + '#' + photos[current].id;
      try {
        await navigator.clipboard.writeText(url);
        copyBtn.textContent = 'Copied';
      } catch {
        copyBtn.textContent = 'Copy failed';
      }
      setTimeout(() => (copyBtn.textContent = 'Copy link'), 1500);
    });

    // Deep-link: open the matching photo on load, and react to hash changes
    // (e.g. a map popup link, or back/forward) while on the page.
    function syncFromHash() {
      const idx = idIndex(decodeURIComponent(location.hash.slice(1)));
      if (idx >= 0) (isOpen() ? show : open)(idx);
      else if (isOpen()) close();
    }
    window.addEventListener('hashchange', syncFromHash);
    const startIdx = idIndex(decodeURIComponent(location.hash.slice(1)));
    if (startIdx >= 0) open(startIdx);
  }

  initLightbox();
</script>
