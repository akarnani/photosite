---
import Base from '../layouts/Base.astro';
import PhotoMap from '../components/PhotoMap.astro';
import { getTrips, allPoints, coverPhoto, siteConfig } from '../lib/trips.js';

const trips = getTrips();
const points = allPoints();
const site = siteConfig();
---

<Base>
  <section class="hero">
    <p class="eyebrow">Underwater photography</p>
    <h1>{site.title}</h1>
    <p>Dives, by trip — where each frame was taken, and what swam past the lens.</p>
  </section>

  {
    points.length > 0 && (
      <section>
        <div class="section-head">
          <p class="eyebrow">The map</p>
          <h2>Everywhere the camera has been</h2>
        </div>
        <PhotoMap points={points} id="global-map" cluster={true} height="460px" />
      </section>
    )
  }

  <section>
    <div class="section-head">
      <p class="eyebrow">Trips</p>
      <h2>Recent expeditions</h2>
    </div>

    {
      trips.length === 0 ? (
        <p style="color:var(--mist-dim)">No trips yet. Add one with <code>photosite add-trip</code>.</p>
      ) : (
        <div class="trip-grid">
          {trips.map((trip) => {
            const cover = coverPhoto(trip);
            const meta = [trip.location?.name, trip.dates, `${trip.photos.length} photos`].filter(Boolean).join(' · ');
            return (
              <a class="trip-card" href={`/trips/${trip.slug}/`}>
                {cover && (
                  <img class="cover" src={cover.fallback} width={cover.width} height={cover.height} alt={trip.title} loading="lazy" />
                )}
                <div class="body">
                  <h3>{trip.title}</h3>
                  <p class="meta">{meta}</p>
                </div>
              </a>
            );
          })}
        </div>
      )
    }
  </section>
</Base>
