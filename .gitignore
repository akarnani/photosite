# dependencies
node_modules/

# secrets — R2 credentials live only in rclone's own config, never here
.env
.env.local
secrets*
*.local.*

# site build output and Astro cache
site/dist/
site/.astro/

# local derivative cache used for offline preview (see DESIGN.md §6).
# Ignore everything except the committed example trip, whose tiny placeholder
# derivatives are bundled so the site renders on a fresh clone before any upload.
site/.image-cache/*
!site/.image-cache/example-raja-ampat/

# misc
.DS_Store
*.log
